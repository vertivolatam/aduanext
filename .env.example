# AduaNext — Environment variables (template).
#
# Copy to `.env` and fill in real values. `.env` is gitignored.
# Generate strong passwords with:  openssl rand -base64 32

# ── PostgreSQL (dev) ─────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_DB=aduanext
POSTGRES_PASSWORD=change-me-dev-password

# ── PostgreSQL (test — ephemeral) ────────────────────────────────────
POSTGRES_TEST_USER=postgres
POSTGRES_TEST_DB=aduanext_test
POSTGRES_TEST_PASSWORD=change-me-test-password

# ── Redis (dev) ──────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-dev-password

# ── Redis (test — ephemeral) ─────────────────────────────────────────
REDIS_TEST_PASSWORD=change-me-redis-test-password
